HTTP_ADDR=:8080
METRICS_ADDR=:9090
SHUTDOWN_TIMEOUT=15s
LOG_LEVEL=info

REDIS_ADDR=localhost:6379
REDIS_TIMEOUT=3s
REDIS_RETRIES=3
REDIS_MIN_BACKOFF=100ms
REDIS_MAX_BACKOFF=2s

RATE_LIMIT_ALGORITHM=token_bucket
RATE_LIMIT_CAPACITY=100
RATE_LIMIT_REFILL=1.67
RATE_LIMIT_WINDOW=1m
RATE_LIMIT_KEY_TTL=120
RATE_LIMIT_FAIL_OPEN=true

# Цепочка ключей лимита: ip | user_id | api_key (через запятую, порядок = порядок проверок)
# Пример: ip,user_id — сначала лимит по IP, затем по X-User-ID
RATE_LIMIT_KEYS=ip
RATE_LIMIT_USER_ID_HEADER=X-User-ID
RATE_LIMIT_API_KEY_HEADER=X-API-Key
